# 整书阅读 AI 后端配置 —— 复制为 .env 并填值
PORT=5191

# ===== LLM（OpenAI 兼容协议 /v1/chat/completions）=====
# 本地开发：可用本地 OpenAI 兼容端点；部署：换成你们服务器的 base + key。
AI_BASE_URL=http://localhost:54861/v1
AI_API_KEY=替换为你的_key
# 主模型 + fallback 链（逗号分隔，按顺序降级；同端点多模型或跨站均可）
AI_MODEL=gpt-5.4-mini
AI_FALLBACK_MODELS=gpt-5.4,gpt-5.5
# 每个模型最多重试次数 / 单请求超时(ms)
AI_MAX_RETRIES=2
AI_TIMEOUT_MS=30000

# 前端静态产物目录（相对 server/）；部署时本服务直接 serve 它
DIST_DIR=../dist
